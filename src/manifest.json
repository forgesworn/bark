{
  "manifest_version": 3,
  "name": "Bark",
  "version": "1.3.5",
  "description": "__MSG_extDescription__",
  "default_locale": "en",
  "permissions": [
    "storage",
    "scripting",
    "activeTab"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "content_scripts": [
    {
      "run_at": "document_start",
      "matches": [
        "https://snort.social/*",
        "https://www.snort.social/*",
        "https://primal.net/*",
        "https://www.primal.net/*",
        "https://iris.to/*",
        "https://www.iris.to/*",
        "https://coracle.social/*",
        "https://www.coracle.social/*",
        "https://nostrudel.ninja/*",
        "https://www.nostrudel.ninja/*",
        "https://jumble.social/*",
        "https://www.jumble.social/*",
        "https://yakihonne.com/*",
        "https://www.yakihonne.com/*",
        "https://habla.news/*",
        "https://www.habla.news/*",
        "https://zap.stream/*",
        "https://www.zap.stream/*",
        "https://njump.me/*",
        "https://www.njump.me/*",
        "https://nostter.app/*",
        "https://www.nostter.app/*",
        "https://satellite.earth/*",
        "https://www.satellite.earth/*",
        "http://localhost/*",
        "http://127.0.0.1/*"
      ],
      "js": [
        "content-script.js"
      ],
      "all_frames": false
    },
    {
      "run_at": "document_start",
      "matches": [
        "https://snort.social/*",
        "https://www.snort.social/*",
        "https://primal.net/*",
        "https://www.primal.net/*",
        "https://iris.to/*",
        "https://www.iris.to/*",
        "https://coracle.social/*",
        "https://www.coracle.social/*",
        "https://nostrudel.ninja/*",
        "https://www.nostrudel.ninja/*",
        "https://jumble.social/*",
        "https://www.jumble.social/*",
        "https://yakihonne.com/*",
        "https://www.yakihonne.com/*",
        "https://habla.news/*",
        "https://www.habla.news/*",
        "https://zap.stream/*",
        "https://www.zap.stream/*",
        "https://njump.me/*",
        "https://www.njump.me/*",
        "https://nostter.app/*",
        "https://www.nostter.app/*",
        "https://satellite.earth/*",
        "https://www.satellite.earth/*",
        "http://localhost/*",
        "http://127.0.0.1/*"
      ],
      "js": [
        "provider.js"
      ],
      "world": "MAIN",
      "all_frames": false
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/bark-16.png",
      "48": "icons/bark-48.png",
      "128": "icons/bark-128.png"
    }
  },
  "icons": {
    "16": "icons/bark-16.png",
    "48": "icons/bark-48.png",
    "128": "icons/bark-128.png"
  }
}
