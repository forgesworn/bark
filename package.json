{
  "name": "@forgesworn/bark",
  "version": "1.0.0",
  "description": "Heartwood-aware NIP-07 browser extension. Signs through your Heartwood device via NIP-46.",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node esbuild.config.js",
    "watch": "node esbuild.config.js --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "package": "node esbuild.config.js --package"
  },
  "keywords": [
    "nostr",
    "nip-07",
    "nip-46",
    "browser-extension",
    "remote-signing",
    "heartwood",
    "nsec-tree",
    "persona",
    "signer"
  ],
  "license": "MIT",
  "devDependencies": {
    "esbuild": "^0.25.0",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "nostr-tools": "^2.23.0"
  }
}
